{
  "name": "berrygo/webapp",
  "description": "Веб-приложение доставки ягод и фруктов BerryGo",
  "type": "project",
  "require": {
    "php": ">=8.0",
    "vlucas/phpdotenv": "^5.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "start": "php -S localhost:8000 -t .",
    "migrate": "php bin/migrate.php up",
    "test": "vendor/bin/phpunit"
  },
  "config": {
    "optimize-autoloader": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
